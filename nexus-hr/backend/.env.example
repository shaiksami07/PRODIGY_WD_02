# ============================
# NexusHR Server Environment Variables
# ============================

# App
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# Database
MONGO_URI=mongodb+srv://_db_user:<PASSWORD>@cluster0.pt3mqh2.mongodb.net/?appName=Cluster0

# JWT
JWT_ACCESS_SECRET=replace_with_a_long_random_string
JWT_REFRESH_SECRET=replace_with_a_different_long_random_string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Cookies
COOKIE_SECRET=replace_with_a_long_random_string

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

# File Uploads
MAX_UPLOAD_SIZE_MB=5

# Bcrypt
BCRYPT_SALT_ROUNDS=12
